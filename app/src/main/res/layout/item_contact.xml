<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/bg_dark_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="#1F2A38"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Avatar Circular -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardContactAvatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardBackgroundColor="#1F2A38"
            app:cardCornerRadius="24dp"
            app:strokeWidth="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imgContactIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_app_logo"
                android:contentDescription="Avatar" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Nombre del Contacto -->
        <TextView
            android:id="@+id/txtContactName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="12dp"
            android:text="Nombre Contacto"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/btnContactCall"
            app:layout_constraintStart_toEndOf="@id/cardContactAvatar"
            app:layout_constraintTop_toTopOf="@id/cardContactAvatar" />

        <!-- Número del Contacto -->
        <TextView
            android:id="@+id/txtContactNumber"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="2dp"
            android:text="+54 11 1234-5678"
            android:textColor="@color/text_light_gray"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@id/btnContactCall"
            app:layout_constraintStart_toEndOf="@id/cardContactAvatar"
            app:layout_constraintTop_toBottomOf="@id/txtContactName" />

        <!-- Botón Llamar (Llamada Rápida) -->
        <ImageButton
            android:id="@+id/btnContactCall"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/btn_call_control_bg"
            android:src="@drawable/ic_call_btn"
            android:padding="10dp"
            android:contentDescription="Call Contact"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnContactChat"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Botón Chatear (Mensaje Rápido) -->
        <ImageButton
            android:id="@+id/btnContactChat"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/btn_call_control_bg"
            android:src="@drawable/ic_chat_btn"
            android:padding="10dp"
            android:contentDescription="Chat Contact"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
