<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="@dimen/margin_normal">

    <!-- Título -->
    <TextView
        android:id="@+id/txtHistoryTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Historial de Llamadas"
        android:textColor="@color/text_white"
        android:textSize="@dimen/text_size_title"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Botón Borrar Todo -->
    <ImageButton
        android:id="@+id/btnClearHistory"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_delete"
        android:contentDescription="Clear Call History"
        app:tint="@color/hangup_red"
        app:layout_constraintBottom_toBottomOf="@id/txtHistoryTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/txtHistoryTitle" />

    <!-- Listado RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCallHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtHistoryTitle"
        tools:listitem="@layout/item_call_history" />

    <!-- Mensaje Vacío -->
    <TextView
        android:id="@+id/txtHistoryEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No hay registros de llamadas"
        android:textColor="@color/text_light_gray"
        android:textSize="@dimen/text_size_body"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
