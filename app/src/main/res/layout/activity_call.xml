<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0E14"
    tools:context=".ui.call.CallActivity">

    <!-- Fondo con gradiente oscuro sutil -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/call_bg_gradient" />

    <!-- Barra Superior: Minimizar -->
    <ImageButton
        android:id="@+id/btnMinimize"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_minimize"
        android:contentDescription="Minimizar llamada"
        app:tint="@color/text_white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Título / Estado de Proximidad -->
    <TextView
        android:id="@+id/txtHeaderTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/text_light_gray"
        android:textSize="13sp"
        android:letterSpacing="0.05"
        app:layout_constraintBottom_toBottomOf="@id/btnMinimize"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnMinimize" />

    <!-- Botón Agregar Participante (Conferencia) -->
    <ImageButton
        android:id="@+id/btnAddParticipant"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="20dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_add"
        android:contentDescription="Agregar participante"
        android:visibility="gone"
        app:tint="@color/text_white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Contenedor del Avatar Neumórfico -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardAvatar"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="70dp"
        app:cardBackgroundColor="#1F2A38"
        app:cardCornerRadius="60dp"
        app:cardElevation="12dp"
        app:strokeColor="#3300E5FF"
        app:strokeWidth="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imgCallAvatar"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_app_logo"
            android:contentDescription="Avatar" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Nombre del Contacto -->
    <TextView
        android:id="@+id/txtCallName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Nombre del Contacto"
        android:textColor="@color/text_white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardAvatar" />

    <!-- Número del Contacto -->
    <TextView
        android:id="@+id/txtCallNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="+54 11 1234 5678"
        android:textColor="@color/text_light_gray"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtCallName" />

    <!-- Estado de la Llamada -->
    <TextView
        android:id="@+id/txtCallStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Llamando..."
        android:textColor="#00E5FF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtCallNumber" />

    <!-- Cronómetro (Visible al conectar) -->
    <TextView
        android:id="@+id/txtCallDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="00:00"
        android:textColor="@color/text_white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtCallStatus" />

    <!-- Sección de Conferencia -->
    <LinearLayout
        android:id="@+id/layoutConference"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/txtCallDuration"
        app:layout_constraintBottom_toTopOf="@id/layoutCallControls"
        app:layout_constraintVertical_bias="0.3">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Participantes"
            android:textColor="#00E5FF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/layoutConferenceParticipants"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center_horizontal">

            <Button
                android:id="@+id/btnMerge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fusionar"
                android:visibility="gone"
                android:layout_marginEnd="8dp"
                android:backgroundTint="@color/call_green"
                android:textColor="@color/text_white" />

            <Button
                android:id="@+id/btnSwap"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alternar"
                android:visibility="gone"
                android:backgroundTint="@color/bg_dark_card"
                android:textColor="@color/text_white" />
        </LinearLayout>
    </LinearLayout>

    <!-- Panel de Controles de Llamada (Botones Circulares Simétricos) -->
    <LinearLayout
        android:id="@+id/layoutCallControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toTopOf="@id/layoutCallActions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Botón Silenciar Micrófono -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="40dp">

            <ImageButton
                android:id="@+id/btnMute"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/btn_call_control_bg"
                android:src="@drawable/ic_mic"
                android:contentDescription="Mute Mic"
                app:tint="@color/text_white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/btn_mute"
                android:textColor="@color/text_light_gray"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Botón Activar Altavoz -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnSpeaker"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/btn_call_control_bg"
                android:src="@drawable/ic_speaker"
                android:contentDescription="Speaker Mode"
                app:tint="@color/text_white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/btn_speaker"
                android:textColor="@color/text_light_gray"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Botones de Acción Principal (Colgar / Contestar) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutCallActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="60dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Botón de Colgar (Rojo Flotante Grandes Dimensiones) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnHangup"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:backgroundTint="#EF4444"
            android:src="@drawable/ic_phone_end"
            android:contentDescription="Hangup Call"
            app:tint="@color/text_white"
            app:fabCustomSize="72dp"
            app:maxImageSize="32dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Botón de Contestar (Verde Flotante - Solo llamadas entrantes) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnAccept"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginEnd="60dp"
            android:backgroundTint="#22C55E"
            android:src="@drawable/ic_phone_answer"
            android:contentDescription="Accept Call"
            app:tint="@color/text_white"
            app:fabCustomSize="72dp"
            app:maxImageSize="32dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnHangup"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
