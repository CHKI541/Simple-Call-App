<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/bg_dark_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="#1F2A38"
    app:strokeWidth="1dp"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardConvAvatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardBackgroundColor="#1F2A38"
            app:cardCornerRadius="24dp"
            app:strokeWidth="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imgConvIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_chat_btn"
                android:contentDescription="Avatar Chat" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/txtConvName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="12dp"
            android:text="Nombre Contacto"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/txtConvTime"
            app:layout_constraintStart_toEndOf="@id/cardConvAvatar"
            app:layout_constraintTop_toTopOf="@id/cardConvAvatar" />

        <TextView
            android:id="@+id/txtConvLastMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="2dp"
            android:text="Último mensaje..."
            android:textColor="@color/text_light_gray"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/cardConvAvatar"
            app:layout_constraintTop_toBottomOf="@id/txtConvName" />

        <TextView
            android:id="@+id/txtConvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:30"
            android:textColor="#00E5FF"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/txtConvName"
            app:layout_constraintBottom_toBottomOf="@id/txtConvName" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
